DROP TABLE IF EXISTS `store`;

CREATE TABLE `store` (
`store_id` INTEGER NOT NULL ,
`customer_id` INTEGER NOT NULL,
`product_id` INTEGER NOT NULL,
`c_date` date DEFAULT NULL,
`rr` TEXT DEFAULT NULL,
`po` TEXT DEFAULT NULL,
`carrier` TEXT DEFAULT NULL,
`received_transfarred` TEXT DEFAULT NULL,
`joints_in` TEXT DEFAULT NULL,
`joints_out` TEXT DEFAULT NULL,
`footage` TEXT DEFAULT NULL,
`attachment` TEXT NOT NULL,
`manufacturer` TEXT DEFAULT NULL,
`rack` TEXT DEFAULT NULL,
`afe` TEXT DEFAULT NULL,
`added_by` INTEGER NOT NULL,
`created_date` datetime NOT NULL,
PRIMARY KEY (`store_id`)
