PRAGMA journal_mode = MEMORY;
PRAGMA synchronous = OFF;
PRAGMA foreign_keys = OFF;
PRAGMA ignore_check_constraints = OFF;
PRAGMA auto_vacuum = NONE;
PRAGMA secure_delete = OFF;
BEGIN TRANSACTION;

DROP TABLE IF EXISTS `email_template`;

CREATE TABLE `email_template` (
`id` INTEGER NOT NULL ,
`type` TEXT  NOT NULL,
`subject` TEXT  NOT NULL,
`plain_body` text  NOT NULL,
PRIMARY KEY (`id`)
);
INSERT INTO `email_template` (`id`, `type`, `subject`, `plain_body`) VALUES (12,'FORGOT_PASSWORD','Forget password link','Dear ({username}),\r\n\r\nYou have requested to update, or have forgotten your password with ({server_name}).\r\nPlease click the following link to create new password : {new_link}\r\n\r\nThank You.');
DROP TABLE IF EXISTS `products`;

CREATE TABLE `products` (
`product_id` INTEGER NOT NULL ,
`outside_diameter` TEXT DEFAULT NULL,
`wall_thickness` TEXT DEFAULT NULL,
`ibs_per_foot` TEXT DEFAULT NULL,
`end_type` TEXT DEFAULT NULL,
`grade` TEXT DEFAULT NULL,
`coating` TEXT DEFAULT NULL,
`foreman` TEXT DEFAULT NULL,
`customer_id` INTEGER NOT NULL,
PRIMARY KEY (`product_id`)
);
